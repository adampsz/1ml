include List;

do log "Set";

type ORD =
{
  type t;
  (<=) : t -> t -> bool;
};

type SET =
{
  type set;
  type elem;
  type t = set;
  empty : set;
  add : elem -> set -> set;
  mem : elem -> set -> bool;
  card : set -> int;
};

Set (Elem : ORD) :> SET with type elem = Elem.t =
{
  type elem = Elem.t;
  type set = (int, elem -> bool);
  type t = set;
  empty = (0, fun (x : elem) => false);
  card (s : set) = s.0;
  mem (x : elem) (s : set) = s.1 x;
  add (x : elem) (s : set) =
    if mem x s then s
    else (s.0 + 1, fun (y : elem) => x == y || mem y s) : set;
};

do log "Map";

type MAP =
{
  type map a;
  type key;
  type t a = map a;
  empty 'a : map a;
  add 'a : key -> a -> map a -> map a;
  lookup 'a : key -> map a -> opt a;
};

Map (Key : ORD) :> MAP with type key = Key.t =
{
  type key = Key.t;
  type map a = key -> opt a;
  t = map;
  empty x = none;
  lookup x m = m x;
  add x y m z = if x == z then some y else m x;
};

do log "Tests";

TestSetAndMap =
{
  S = Set Int;
  s = S.add 3 (S.add 5 (S.empty));
  do Bool.print (S.mem 5 s); do print "\n";
};


