log = {
    type text = extern "string";
    print = extern "String.print": text -> ();
    (++) = extern "String.++": text -> text -> text;
    log s = print (s ++ "\n");
}.log;

do log "Bool";

Bool =
{
  type bool = extern "bool";
  type t = bool;
  true = extern "Bool.true": bool;
  false = extern "Bool.false": bool;
  not b = if b then false else true;
  print = extern "Bool.print": bool -> ();
};
type bool = Bool.t;
true = Bool.true;
false = Bool.false;
not = Bool.not;

do log "Toplevel";

(==) 'a (x : a) (y : a) = (extern "==": a -> a -> bool) x y;
(<>) 'a (x : a) (y : a) = not (x == y);

do log "Int";

Int =
{
  type int = extern "int";
  type t = int;
  (+) = extern "Int.+": int -> int -> int;
  (-) = extern "Int.-": int -> int -> int;
  (*) = extern "Int.*": int -> int -> int;
  (<) = extern "Int.<": int -> int -> bool;
  (>) = extern "Int.>": int -> int -> bool;
  (<=) = extern "Int.<=": int -> int -> bool;
  (>=) = extern "Int.>=": int -> int -> bool;
  print = extern "Int.print": int -> ();
};
type int = Int.t;
(+) = Int.(+);
(-) = Int.(-);
(*) = Int.(*);
(<) = Int.(<);
(>) = Int.(>);
(<=) = Int.(<=);
(>=) = Int.(>=);

do log "Char";

Char =
{
  type char = extern "char";
  type t = char;
  toInt = extern "Char.toInt": char -> int;
  fromInt = extern "Char.fromInt": int -> char;
  print = extern "Char.print": char -> ();
};
type char = Char.t;

do log "Text";

Text =
{
  type text = extern "string";
  type t = text;
  (++) = extern "String.++": text -> text -> text;
  (<) = extern "String.<": text -> text -> bool;
  (>) = extern "String.>": text -> text -> bool;
  (<=) = extern "String.<=": text -> text -> bool;
  (>=) = extern "String.>=": text -> text -> bool;
  length t = extern "String.length": text -> int;
  sub = extern "String.sub": text -> int -> int -> text;
  fromChar = extern "String.fromChar": char -> text;
  print = extern "String.print": text -> ();
};
type text = Text.t;
(++) = Text.(++);
print = Text.print;

do log "Opt";

type OPT =
{
  type opt a;
  none 'a : opt a;
  some 'a : a -> opt a;
  caseopt 'a 'b : opt a -> b -> (a -> b) -> b;
};
Opt :> OPT =
{
  type opt a = wrap ((b : type) => b -> (a -> b) -> b);
  none = wrap (fun (b : type) (n : b) (s : _ -> b) => n) : opt _;
  some x = wrap (fun (b : type) (n : b) (s : _ -> b) => s x) : opt _;
  caseopt xo = (unwrap xo : opt _) (type _);
};
include Opt;

do log "Alt";

type ALT =
{
  type alt a b;
  left 'a 'b : a -> alt a b;
  right 'a 'b : b -> alt a b;
  casealt 'a 'b 'c : alt a b -> (a -> c) -> (b -> c) -> c;
};
Alt :> ALT =
{
  type alt a b = wrap ((c : type) => (a -> c) -> (b -> c) -> c);
  left x = wrap (fun (c : type) (l : _ -> c) (r : _ -> c) => l x) : alt _ _;
  right x = wrap (fun (c : type) (l : _ -> c) (r : _ -> c) => r x) : alt _ _;
  casealt xy = (unwrap xy : alt _ _) (type _);
};
include Alt;

do log "List";

type LIST_CORE =
{
  type list a;
  nil 'a : list a;
  cons 'a : a -> list a -> list a;
  foldr 'a 'b : list a -> b -> (a -> b -> b) -> b;
};
type LIST =
{
  include LIST_CORE;
  caselist 'a 'b : list a -> b -> (a -> list a -> b) -> b;
  isNil 'a : list a -> bool;
  head 'a : list a -> opt a;
  tail 'a : list a -> opt (list a);
  length 'a : list a -> int;
  cat 'a : list a -> list a -> list a;
  rev 'a : list a -> list a;
  nth 'a : list a -> int -> opt a;
  map 'a 'b : list a -> (a -> b) -> list b;
  foldl 'a 'b : list a -> b -> (b -> a -> b) -> b;
(*  foldr 'a 'b : list a -> b -> (a -> b -> b) -> b; *)
};
List :> LIST =
{
  include
  {
    type list a = wrap ((b : type) => b -> (a -> b -> b) -> b);
    nil = wrap (fun (b : type) (n : b) (c : _ -> b -> b) => n) : list _;
    cons x xs =
      wrap (fun (b : type) (n : b) (c : _ -> b -> b) =>
        c x ((unwrap xs : list _) b n c)) : list _;
    foldr xs = (unwrap xs : list _) (type _);
  } :> LIST_CORE;
  isNil xs = foldr xs true (fun _ _ => false);
  head xs = foldr xs none (fun x _ => some x);
  tail xs =
    (foldr xs (nil, none)
      (fun x (acc : (_, _)) => (cons x (acc.0), some (acc.0)))) .1;
  caselist xs n c =
    caseopt (head xs) n (fun x => caseopt (tail xs) n (fun xs' => c x xs'));
  length xs = foldr xs 0 (fun _ n => n + 1);
  cat xs1 xs2 = foldr xs1 xs2 cons;
  rev xs = foldr xs nil (fun x xs => cat xs (cons x nil));
  map xs f = foldr xs nil (fun x => cons (f x));
  foldl xs x f = foldr (rev xs) x (fun x y => f y x);
  nth xs n =
    (foldr xs (length xs - 1, none) (fun x (p : (_, _)) =>
      (p.0 - 1, if p.0 == n then some x else p.1)
    )) .1;
};
